// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ReleaseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  REFUNDED
  CANCELED
}

enum PricingMode {
  FREE
  FIXED
  PWYW
}

enum PreviewMode {
  CLIP
  FULL
}

enum AssetRole {
  MASTER
  PREVIEW
  DELIVERY
}

enum TranscodeStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum TranscodeJobKind {
  PREVIEW_CLIP
  DELIVERY_FORMATS
}

enum DeliveryFormat {
  MP3
  M4A
  FLAC
}

enum ReleaseType {
  ALBUM
  EP
  SINGLE
  COMPILATION
  MIXTAPE
  LIVE_ALBUM
  SOUNDTRACK_SCORE
  DEMO
  BOOTLEG
  REMIX
  OTHER
}

enum StoreStatus {
  SETUP
  PRIVATE
  PUBLIC
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String         @default("")
  emailVerified Boolean        @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]
  memberships   Membership[]
  organizations Organization[] @relation("OrganizationOwner")
  artists       Artist[]       @relation("ArtistOwner")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String   @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Organization {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  ownerId            String
  owner              User                @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships        Membership[]
  artists            Artist[]
  customers          Customer[]
  orders             Order[]
  releases           Release[]
  storeSettings      StoreSettings?
  buyerLibraryTokens BuyerLibraryToken[]
  transcodeJobs      TranscodeJob[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Artist {
  id             String       @id @default(cuid())
  organizationId String
  ownerId        String?
  name           String
  slug           String
  location       String?
  bio            String?
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          User?        @relation("ArtistOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  releases       Release[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, name])
}

model Release {
  id                String                @id @default(cuid())
  organizationId    String
  artistId          String
  featuredTrackId   String?
  title             String
  releaseType       ReleaseType           @default(ALBUM)
  label             String                @default("Independent")
  slug              String
  description       String?
  coverImageUrl     String?
  priceCents        Int                   @default(0)
  currency          String                @default("USD")
  pricingMode       PricingMode           @default(FREE)
  fixedPriceCents   Int?
  minimumPriceCents Int?
  deliveryFormats   DeliveryFormat[]      @default([MP3, M4A, FLAC])
  isLossyOnly       Boolean               @default(false)
  status            ReleaseStatus         @default(DRAFT)
  releaseDate       DateTime              @default(now())
  publishedAt       DateTime?
  deletedAt         DateTime?
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  artist            Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  featuredTrack     ReleaseTrack?         @relation("ReleaseFeaturedTrack", fields: [featuredTrackId], references: [id], onDelete: SetNull)
  tracks            ReleaseTrack[]
  files             ReleaseFile[]
  orderItems        OrderItem[]
  entitlements      DownloadEntitlement[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([organizationId, slug])
  @@index([artistId, status])
  @@index([featuredTrackId])
}

model StoreSettings {
  id                    String       @id @default(cuid())
  organizationId        String       @unique
  storeStatus           StoreStatus  @default(SETUP)
  setupComplete         Boolean      @default(false)
  storeName             String?
  brandName             String?
  brandTagline          String?
  brandDescription      String?
  currency              String       @default("USD")
  defaultPreviewMode    PreviewMode  @default(CLIP)
  defaultPreviewSeconds Int          @default(30)
  featuredReleaseId     String?
  contactEmail          String?
  contactName           String?
  supportEmail          String?
  websiteUrl            String?
  instagramUrl          String?
  xUrl                  String?
  tiktokUrl             String?
  youtubeUrl            String?
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model ReleaseTrack {
  id             String         @id @default(cuid())
  releaseId      String
  title          String
  artistOverride String?
  trackNumber    Int
  durationMs     Int?
  lyrics         String?
  credits        String?
  previewMode    PreviewMode    @default(CLIP)
  previewSeconds Int?
  release        Release        @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  featuredOnReleases Release[]  @relation("ReleaseFeaturedTrack")
  assets         TrackAsset[]
  transcodeJobs  TranscodeJob[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([releaseId, trackNumber])
  @@index([releaseId, trackNumber])
}

model TrackAsset {
  id            String            @id @default(cuid())
  trackId       String
  storageKey    String
  format        String
  mimeType      String
  fileSizeBytes Int
  bitrateKbps   Int?
  sampleRateHz  Int?
  channels      Int?
  isLossless    Boolean           @default(false)
  assetRole     AssetRole         @default(MASTER)
  track         ReleaseTrack      @relation(fields: [trackId], references: [id], onDelete: Cascade)
  sourceJobs    TranscodeJob[]    @relation("TranscodeSourceAsset")
  outputRecords TranscodeOutput[] @relation("TranscodeOutputAsset")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([trackId, storageKey])
  @@index([trackId, assetRole])
}

model ReleaseFile {
  id           String                @id @default(cuid())
  releaseId    String
  fileName     String
  storageKey   String
  mimeType     String
  sizeBytes    Int
  sortOrder    Int                   @default(0)
  release      Release               @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  entitlements DownloadEntitlement[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([releaseId, storageKey])
  @@index([releaseId, sortOrder])
}

model Customer {
  id                 String                @id @default(cuid())
  organizationId     String
  email              String
  name               String?
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders             Order[]
  entitlements       DownloadEntitlement[]
  buyerLibraryTokens BuyerLibraryToken[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId, name])
}

model Order {
  id                 String       @id @default(cuid())
  organizationId     String
  customerId         String
  orderNumber        String
  status             OrderStatus  @default(PENDING)
  currency           String       @default("USD")
  subtotalCents      Int          @default(0)
  taxCents           Int          @default(0)
  totalCents         Int          @default(0)
  checkoutSessionId  String?      @unique
  paymentIntentId    String?
  taxCentsFromStripe Int?
  emailStatus        EmailStatus  @default(PENDING)
  emailSentAt        DateTime?
  paidAt             DateTime?
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer           Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items              OrderItem[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([organizationId, orderNumber])
  @@index([customerId, createdAt])
}

model BuyerLibraryToken {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String
  token          String       @unique
  expiresAt      DateTime?
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  accessCount    Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([customerId])
  @@index([organizationId, revokedAt, expiresAt])
}

model TranscodeJob {
  id             String            @id @default(cuid())
  organizationId String
  trackId        String
  sourceAssetId  String
  jobKind        TranscodeJobKind
  attemptCount   Int               @default(0)
  nextRetryAt    DateTime?
  status         TranscodeStatus   @default(QUEUED)
  errorMessage   String?
  queuedAt       DateTime          @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  track          ReleaseTrack      @relation(fields: [trackId], references: [id], onDelete: Cascade)
  sourceAsset    TrackAsset        @relation("TranscodeSourceAsset", fields: [sourceAssetId], references: [id], onDelete: Cascade)
  outputs        TranscodeOutput[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, queuedAt])
  @@index([trackId])
  @@index([organizationId, sourceAssetId, jobKind, status])
  @@index([status, nextRetryAt, queuedAt])
}

model TranscodeOutput {
  id            String       @id @default(cuid())
  jobId         String
  outputAssetId String
  format        String
  storageKey    String
  mimeType      String
  fileSizeBytes Int
  job           TranscodeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  outputAsset   TrackAsset   @relation("TranscodeOutputAsset", fields: [outputAssetId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([jobId, format])
  @@index([outputAssetId])
}

model OrderItem {
  id              String                @id @default(cuid())
  orderId         String
  releaseId       String
  lineNumber      Int
  quantity        Int                   @default(1)
  unitPriceCents  Int
  totalPriceCents Int
  order           Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  release         Release               @relation(fields: [releaseId], references: [id], onDelete: Restrict)
  entitlements    DownloadEntitlement[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([orderId, lineNumber])
  @@index([releaseId])
}

model DownloadEntitlement {
  id            String      @id @default(cuid())
  customerId    String
  releaseId     String
  releaseFileId String
  orderItemId   String
  token         String      @unique
  expiresAt     DateTime?
  redeemedAt    DateTime?
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  release       Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  releaseFile   ReleaseFile @relation(fields: [releaseFileId], references: [id], onDelete: Cascade)
  orderItem     OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([orderItemId, releaseFileId])
  @@index([customerId, releaseId])
}

model SetupWizardState {
  id                String    @id @default(cuid())
  singletonKey      Int       @default(1) @unique
  orgName           String?
  storeName         String?
  contactEmail      String?
  currency          String    @default("USD")
  smtpHost          String?
  smtpProviderPreset String    @default("custom")
  smtpPort          Int?
  smtpUsername      String?
  smtpPassword      String?
  smtpSecure        Boolean   @default(false)
  smtpFromEmail     String?
  smtpTestRecipient String?
  smtpTestPassedAt  DateTime?
  smtpLastTestError String?
  storageMode       String    @default("GARAGE")
  storageEndpoint   String?
  storageRegion     String?
  storageBucket     String?
  storageAccessKeyId String?
  storageSecretAccessKey String?
  storageUsePathStyle Boolean @default(false)
  storageValidatedAt DateTime?
  storageLastError   String?
  stripeSecretKey    String?
  stripeWebhookSecret String?
  stripeVerifiedAt   DateTime?
  stripeLastError    String?
  adminEmail         String?
  adminMagicLinkSentAt DateTime?
  adminMagicLinkLastError String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model SetupToken {
  id        String   @id @default(cuid())
  token     String?  @unique
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consumedAt, expiresAt])
}
