{
  "name": "merch-table",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run -s db:generate",
    "dev": "next dev",
    "build": "npm run -s db:generate && next build",
    "prestart": "npm run -s db:generate",
    "start": "next start",
    "worker": "node --env-file=.env --import tsx src/worker/transcode-worker.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "lint": "eslint",
    "typecheck": "npm run -s db:generate && next typegen && tsc --noEmit",
    "check": "npm run db:validate && npm run -s lint && npm run -s typecheck && npm test",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:status": "prisma migrate status",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "audit:currency": "node --env-file=.env --import tsx scripts/audit-currency-minor-units.ts",
    "audit:currency:fix-sql": "node --env-file=.env --import tsx scripts/generate-currency-fix-sql.ts",
    "infra:garage:bootstrap": "bash ./scripts/bootstrap-garage.sh",
    "infra:up": "docker compose up -d postgres redis garage && npm run -s infra:garage:bootstrap",
    "infra:up:core": "npm run -s infra:up",
    "infra:up:all": "docker compose up -d --build && npm run -s infra:garage:bootstrap",
    "infra:up:web": "docker compose up -d --build web worker",
    "infra:down": "docker compose down",
    "infra:ps": "docker compose ps",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "stripe:trigger:checkout-complete": "stripe trigger checkout.session.completed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@better-auth/prisma-adapter": "^1.5.6",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "archiver": "^7.0.1",
    "better-auth": "^1.5.6",
    "howler": "^2.2.4",
    "lucide-react": "^1.8.0",
    "music-metadata": "^11.12.3",
    "next": "^16.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^6.0.4",
    "@types/howler": "^2.2.12",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
