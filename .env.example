# Core app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/merchtable?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
APP_ENCRYPTION_KEY="replace-with-32-byte-base64url-key"
APP_BASE_URL="http://localhost:3000"
STORE_ORG_SLUG="main-store"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CURRENCY="USD"

# SMTP (admin magic-link emails)
SMTP_FROM="no-reply@example.com"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"

# Storage
STORAGE_MODE="GARAGE"
STORAGE_BUCKET="media"
STORAGE_PUBLIC_BASE_URL="http://localhost:3900/media"
STORAGE_ENDPOINT="http://localhost:3900"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY_ID="access-key-id"
STORAGE_SECRET_ACCESS_KEY="secret-access-key"
STORAGE_USE_PATH_STYLE="true"
# Backwards-compatible toggles used only when STORAGE_MODE is not set.
GARAGE_ENABLED="true"
# Legacy toggle retained for older env files: "false" forces external S3 mode.
MINIO_ENABLED="true"

# Worker runtime
REDIS_URL="redis://localhost:6379"
CDN_BASE_URL=""
TRANSCODE_CONCURRENCY="1"
TRANSCODE_QUEUE_KEY="merch-table:transcode:queue"
TRANSCODE_QUEUE_POLL_TIMEOUT_SECONDS="5"
TRANSCODE_SOURCE_ROOT="/tmp/merch-table/source"
TRANSCODE_OUTPUT_ROOT="/tmp/merch-table/output"

# Upload and download limits
MAX_UPLOAD_SIZE_BYTES="2147483648" # 2 GB
MAX_COVER_UPLOAD_SIZE_BYTES="26214400" # 25 MB
SIGNED_URL_EXPIRY_SECONDS="900"
NEXT_PUBLIC_MIN_UPLOAD_BITRATE_KBPS="192"
NEXT_PUBLIC_MIN_UPLOAD_SAMPLE_RATE_HZ="44100"
NEXT_PUBLIC_UPLOAD_QUALITY_MODE="warn"

# Buyer library token behavior
# Empty means non-expiring by default
BUYER_LIBRARY_TOKEN_TTL_SECONDS=""

# Pricing safeguards
MINIMUM_PRICE_FLOOR_CENTS="50"
STRIPE_FEE_ESTIMATE_PERCENT_BPS="290"
STRIPE_FEE_ESTIMATE_FIXED_CENTS="30"

# Rate limiting
RATE_LIMIT_FREE_CHECKOUT_MAX="5"
RATE_LIMIT_FREE_CHECKOUT_WINDOW_SECONDS="3600"
RATE_LIMIT_DOWNLOAD_MAX="120"
RATE_LIMIT_DOWNLOAD_WINDOW_SECONDS="3600"
RATE_LIMIT_UPLOAD_URL_MAX="60"
RATE_LIMIT_UPLOAD_URL_WINDOW_SECONDS="3600"
RATE_LIMIT_CHECKOUT_SESSION_MAX="30"
RATE_LIMIT_CHECKOUT_SESSION_WINDOW_SECONDS="3600"
RATE_LIMIT_SETUP_CLAIM_MAX="20"
RATE_LIMIT_SETUP_CLAIM_WINDOW_SECONDS="900"
RATE_LIMIT_SETUP_SAVE_MAX="120"
RATE_LIMIT_SETUP_SAVE_WINDOW_SECONDS="600"
RATE_LIMIT_SETUP_VERIFY_SMTP_MAX="10"
RATE_LIMIT_SETUP_VERIFY_SMTP_WINDOW_SECONDS="900"
RATE_LIMIT_SETUP_VERIFY_STORAGE_MAX="20"
RATE_LIMIT_SETUP_VERIFY_STORAGE_WINDOW_SECONDS="900"
RATE_LIMIT_SETUP_VERIFY_STRIPE_MAX="20"
RATE_LIMIT_SETUP_VERIFY_STRIPE_WINDOW_SECONDS="900"
RATE_LIMIT_SETUP_ADMIN_MAGIC_LINK_MAX="10"
RATE_LIMIT_SETUP_ADMIN_MAGIC_LINK_WINDOW_SECONDS="900"
RATE_LIMIT_ADMIN_AUTH_REQUEST_IP_MAX="10"
RATE_LIMIT_ADMIN_AUTH_REQUEST_IP_WINDOW_SECONDS="900"
RATE_LIMIT_ADMIN_AUTH_REQUEST_EMAIL_MAX="3"
RATE_LIMIT_ADMIN_AUTH_REQUEST_EMAIL_WINDOW_SECONDS="900"
RATE_LIMIT_ADMIN_AUTH_CONSUME_IP_MAX="30"
RATE_LIMIT_ADMIN_AUTH_CONSUME_IP_WINDOW_SECONDS="900"

# Trust forwarded proxy IP headers (x-forwarded-for / forwarded).
# Keep "false" unless your deployment ensures these headers are set by a trusted proxy.
TRUST_PROXY_HEADERS="false"

# Observability
LOG_LEVEL="info"
