# Core app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/merchtable?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
APP_BASE_URL="http://localhost:3000"
STORE_ORG_SLUG="main-store"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CURRENCY="USD"

# SMTP (admin magic-link emails)
SMTP_FROM="no-reply@example.com"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"

# Storage
STORAGE_BUCKET="media"
STORAGE_PUBLIC_BASE_URL="http://localhost:9000/media"
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY_ID="minioadmin"
STORAGE_SECRET_ACCESS_KEY="minioadmin"
STORAGE_USE_PATH_STYLE="true"
MINIO_ENABLED="true"

# Worker runtime
REDIS_URL="redis://localhost:6379"
CDN_BASE_URL=""
TRANSCODE_CONCURRENCY="1"
TRANSCODE_SOURCE_ROOT="/tmp/merch-table/source"
TRANSCODE_OUTPUT_ROOT="/tmp/merch-table/output"
